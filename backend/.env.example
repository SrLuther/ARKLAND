# =========================================
# ARKLAND Store - Variáveis de Ambiente
# =========================================
# Copie este arquivo para .env e preencha com seus valores

# =========================================
# Tip4Serv API
# =========================================
# Obtenha sua chave em: https://tip4serv.com/dashboard/api-keys
# Formato: sk_live_xxxxxxxxxxxxx
TIP4SERV_API_KEY=sk_live_sua_chave_api_aqui

# URL base da API (deixe como está, é a oficial)
TIP4SERV_API_URL=https://api.tip4serv.com/v1

# =========================================
# Servidor Express
# =========================================
# Porta em que o servidor rodará (padrão: 3000)
PORT=3000

# Ambiente (development/production)
NODE_ENV=development

# =========================================
# CORS - Origens Permitidas
# =========================================
# Separadas por vírgula. Adicione seu domínio em produção
# Exemplos:
# CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000,https://arkland.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

